npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# local database
dashboard.db
dashboard.db-*

# next.js build artifacts (legacy, pre-Tauri rebuild)
.next/
next-env.d.ts
